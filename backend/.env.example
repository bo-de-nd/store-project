PORT=4000

# ─── بيانات الأدمن ───────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# ─── مفتاح JWT ───────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-key

# ─── Supabase / PostgreSQL ───────────────────────
# احصل على هذا الرابط من: Supabase → Settings → Database → Connection string → URI
# استبدل [YOUR-PASSWORD] بكلمة مرور قاعدة بياناتك
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ─── بيانات المتجر ───────────────────────────────
STORE_NAME=متجر لمسة
STORE_WHATSAPP=967777123456

# ─── CORS ────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
